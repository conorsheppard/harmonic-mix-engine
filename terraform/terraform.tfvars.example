# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

# Required: your Azure subscription ID (az account show --query id -o tsv).
# Alternatively export ARM_SUBSCRIPTION_ID and omit this.
subscription_id = "00000000-0000-0000-0000-000000000000"

# Optional overrides (defaults shown):
# location                  = "West Europe"
# name_prefix               = "harmonic-mix-engine"
# vm_size                   = "Standard_B2ls_v2"
# admin_username            = "azureuser"
# git_repo_url              = "https://github.com/conorsheppard/harmonic-mix-engine.git"
# git_branch                = "main"

# Tighten SSH exposure to your own IP, e.g. "203.0.113.4/32" (default "*" = anywhere).
# ssh_source_address_prefix = "*"
